# FitSweetTreat Video Automation - Environment Configuration

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Social Media APIs
TIKTOK_API_KEY=your_tiktok_business_api_key
INSTAGRAM_API_TOKEN=your_instagram_business_account_token
YOUTUBE_API_KEY=your_youtube_api_key

# n8n Configuration
N8N_CHAT_WEBHOOK=http://localhost:5678/webhook/chat-trigger
N8N_CALLBACK_WEBHOOK=http://localhost:5000/n8n-callback

# ComfyUI (Modal) - Used as fallback
COMFYUI_URL=https://chlevin135--modal-comfyui-ui.modal.run

# KokoroTTS (Local)
KOKORO_URL=http://localhost:8000

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash

# HuggingFace Token (for gated models)
HF_TOKEN=hf_your_token_here

# Optional: AWS S3 for video storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=fitsweettreat-videos

# Optional: Redis for distributed callbacks
REDIS_URL=redis://localhost:6379
